# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── AI ──────────────────────────────────────────────────────────────────────
CEREBRAS_API_KEY=your_cerebras_key_here

# ── Market Data (at least one required) ─────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here
POLYGON_API_KEY=your_polygon_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here   # fallback only

# ── Notifications ────────────────────────────────────────────────────────────
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — great for dev / single-server):
DATABASE_URL=sqlite+aiosqlite:///./stock_agent.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stock_agent

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development     # or production
TOP_N_STOCKS=10
DAILY_SCAN_CRON=0 23 * * *  # 11 PM UTC
