# Private beta configuration. Copy to .env locally; set these in Render.

ENVIRONMENT=development
APP_API_KEY=replace-with-a-long-random-private-beta-key
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

CEREBRAS_API_KEY=your-cerebras-api-key
FINNHUB_API_KEY=your-finnhub-api-key
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
DISCORD_WEBHOOK=

DATABASE_URL=sqlite+aiosqlite:///./stock_agent.db
ENABLE_SCHEDULER=false
DAILY_SCAN_CRON=0 23 * * *
TOP_N_STOCKS=10
REFRESH_RATE_LIMIT_PER_MINUTE=5
WEBHOOK_RATE_LIMIT_PER_MINUTE=30
